<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="0" stylesheets="@style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.traktirkopi.BackofficeController">

   <!-- Header Bar -->
   <HBox alignment="CENTER_LEFT" spacing="20" styleClass="backoffice-header">
      <padding>
         <Insets bottom="20" left="30" right="30" top="20" />
      </padding>
      <children>
         <Label styleClass="text-h1" text="Menu Management" />
         <Region HBox.hgrow="ALWAYS" />
         <TextField fx:id="searchField" promptText="🔍  Search menu..." styleClass="backoffice-search" prefWidth="240" />
         <Button mnemonicParsing="false" onAction="#addNewMenu" styleClass="backoffice-btn-add" text="+ Add New Menu" />
      </children>
   </HBox>

   <!-- Menu Table -->
   <TableView fx:id="menuTable" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent;">
      <columns>
         <TableColumn prefWidth="60" text="" />
         <TableColumn prefWidth="260" text="Name" />
         <TableColumn prefWidth="140" text="Category" />
         <TableColumn prefWidth="160" text="Price" />
         <TableColumn prefWidth="120" text="Actions" />
      </columns>
      <VBox.margin>
         <Insets bottom="20" left="20" right="20" top="10" />
      </VBox.margin>
   </TableView>

</VBox>
