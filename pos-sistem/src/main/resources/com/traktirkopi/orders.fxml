<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="0" stylesheets="@style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.traktirkopi.OrdersController">

   <!-- Header Bar -->
   <HBox alignment="CENTER_LEFT" spacing="20" styleClass="backoffice-header">
      <padding>
         <Insets bottom="20" left="30" right="30" top="20" />
      </padding>
      <children>
         <Label styleClass="text-h1" text="Order History" />
         <Region HBox.hgrow="ALWAYS" />
         <TextField fx:id="searchField" promptText="🔍  Search order ID or customer..." styleClass="backoffice-search" prefWidth="280" />
      </children>
   </HBox>

   <!-- Orders Table -->
   <TableView fx:id="ordersTable" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent;">
      <columns>
         <TableColumn prefWidth="120" text="Order ID" />
         <TableColumn prefWidth="160" text="Time" />
         <TableColumn prefWidth="180" text="Customer" />
         <TableColumn prefWidth="140" text="Payment Method" />
         <TableColumn prefWidth="140" text="Total Amount" />
         <TableColumn prefWidth="120" text="Actions" />
      </columns>
      <VBox.margin>
         <Insets bottom="20" left="20" right="20" top="10" />
      </VBox.margin>
   </TableView>

</VBox>
